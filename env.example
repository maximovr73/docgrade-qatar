# Copy this file to .env and fill in real values.
# NEVER commit a real .env file — only this .example stays in version control.

# ── Required ─────────────────────────────────────────────────────────────────
# Your real Anthropic API key. Starts with sk-ant-.
# Get one at https://console.anthropic.com — this is the ONLY place in the
# whole system that should ever hold this value.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8787

# Comma-separated list of frontend origins allowed to call this API.
# In production, set this to your real Cloudflare Pages domain(s) — never "*".
# Example: https://docgrade-qatar.pages.dev,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,https://app.docgrade.example.com

# Comma-separated list of model IDs the frontend is allowed to request.
# The server falls back to DEFAULT_MODEL if the client asks for anything
# outside this list — this is a safety rail against a tampered frontend.
ALLOWED_MODELS=claude-sonnet-4-6
DEFAULT_MODEL=claude-sonnet-4-6

# Requests allowed per IP per minute on rate-limited endpoints
# (/api/analyze, /api/mzsync POST, /api/his-export).
RATE_LIMIT_MAX=30

# ── MOPH sync ────────────────────────────────────────────────────────────────
# Cron expression (5 fields: min hour day-of-month month day-of-week).
# Default: every Sunday at 03:00 server time.
MOPH_CRON=0 3 * * 0

# Override the listing page URL if MOPH restructures their site.
# MOPH_LISTING_URL=https://www.moph.gov.qa/english/medicalregulations/Pages/ClinicalGuidelines.aspx

# Max number of PDF documents to process per sync run (safety cap).
MOPH_MAX_DOCS=300

# Directory an admin can manually drop verified MOPH guideline PDFs into.
# Used as a fallback since the live MOPH portal has returned HTTP 403 to
# automated requests in testing — see src/services/mophSync.js for details.
# MOPH_MANUAL_DROP_DIR=./data/moph-manual-drop

# ── Storage ──────────────────────────────────────────────────────────────────
# Postgres connection string. On Railway/Render, attach their managed
# Postgres addon to this service and this gets injected automatically — you
# usually don't need to set it manually. For local development, point it at
# any Postgres instance you have running:
DATABASE_URL=postgres://user:password@localhost:5432/docgrade
